# Database Configuration
# NOTE: For local development, update appsettings.json directly
# For production deployment, use environment variables below:

# SQL Server with username/password:
ConnectionStrings__DefaultConnection=Server=YOUR_SERVER;Database=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;MultipleActiveResultSets=true;TrustServerCertificate=True;

# OR Windows Authentication (like local):
# ConnectionStrings__DefaultConnection=Server=YOUR_SERVER\\INSTANCE;Database=Indus_Migration;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True;

# CORS Configuration (comma-separated list)
Cors__AllowedOrigins__0=https://yourdomain.com
Cors__AllowedOrigins__1=https://www.yourdomain.com

# Security Settings
Security__RequireHttps=true
Security__EnableStrictTransportSecurity=true
Security__HstsMaxAge=31536000

# Email Configuration
EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__SenderEmail=noreply@yourdomain.com
EmailSettings__SenderName=MigraTrack Pro
EmailSettings__EnableSsl=true
EmailSettings__Username=YOUR_EMAIL
EmailSettings__Password=YOUR_EMAIL_PASSWORD

# Logging
Logging__LogLevel__Default=Warning
Logging__LogLevel__Microsoft.AspNetCore=Warning

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000
