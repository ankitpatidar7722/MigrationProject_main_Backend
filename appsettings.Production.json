{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Error"
    },
    "Console": {
      "IncludeScopes": true,
      "TimestampFormat": "[HH:mm:ss] ",
      "LogToStandardErrorThreshold": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Security": {
    "RequireHttps": true,
    "EnableStrictTransportSecurity": true,
    "HstsMaxAge": 31536000
  },
  "EmailSettings": {
    "SmtpServer": "",
    "SmtpPort": 587,
    "SenderEmail": "",
    "SenderName": "MigraTrack Pro",
    "EnableSsl": true
  }
}
